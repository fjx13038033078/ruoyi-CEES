<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.university.mapper.MajorMapper">

    <resultMap type="com.ruoyi.university.domain.Major" id="MajorResult">
        <id property="majorId" column="major_id"/>
        <result property="universityId" column="university_id"/>
        <result property="majorNum" column="major_num"/>
        <result property="majorName" column="major_name"/>
        <result property="subject" column="subject"/>
        <result property="description" column="description"/>
        <result property="minScore2023" column="min_score_2023"/>
        <result property="minScore2024" column="min_score_2024"/>
        <result property="minScore2025" column="min_score_2025"/>
    </resultMap>

    <!-- 根据条件查询专业信息；scoreYear 指定分数线筛选/排序年份，未指定则按最新可用分数 COALESCE -->
    <select id="getAllMajors" parameterType="map" resultMap="MajorResult">
        SELECT * FROM cers_major
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND major_name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        <if test="subject != null">
            AND subject = #{subject}
        </if>
        <choose>
            <when test="scoreYear != null and scoreYear == 2023">
                <if test="minScore != null and minScore > 0">
                    AND min_score_2023 &gt;= #{minScore}
                </if>
                <if test="maxScore != null and maxScore > 0">
                    AND min_score_2023 &lt;= #{maxScore}
                </if>
            </when>
            <when test="scoreYear != null and scoreYear == 2024">
                <if test="minScore != null and minScore > 0">
                    AND min_score_2024 &gt;= #{minScore}
                </if>
                <if test="maxScore != null and maxScore > 0">
                    AND min_score_2024 &lt;= #{maxScore}
                </if>
            </when>
            <when test="scoreYear != null and scoreYear == 2025">
                <if test="minScore != null and minScore > 0">
                    AND min_score_2025 &gt;= #{minScore}
                </if>
                <if test="maxScore != null and maxScore > 0">
                    AND min_score_2025 &lt;= #{maxScore}
                </if>
            </when>
            <otherwise>
                <if test="minScore != null and minScore > 0">
                    AND COALESCE(min_score_2025, min_score_2024, min_score_2023) &gt;= #{minScore}
                </if>
                <if test="maxScore != null and maxScore > 0">
                    AND COALESCE(min_score_2025, min_score_2024, min_score_2023) &lt;= #{maxScore}
                </if>
            </otherwise>
        </choose>
        <choose>
            <when test="scoreYear != null and scoreYear == 2023">
                ORDER BY min_score_2023
            </when>
            <when test="scoreYear != null and scoreYear == 2024">
                ORDER BY min_score_2024
            </when>
            <when test="scoreYear != null and scoreYear == 2025">
                ORDER BY min_score_2025
            </when>
            <otherwise>
                ORDER BY COALESCE(min_score_2025, min_score_2024, min_score_2023)
            </otherwise>
        </choose>
    </select>

    <!-- 根据专业ID获取专业信息 -->
    <select id="getMajorById" parameterType="Long" resultMap="MajorResult">
        SELECT * FROM cers_major WHERE major_id = #{majorId}
    </select>

    <!-- 根据学校ID获取该校所有专业信息 -->
    <select id="getMajorsByUniversityId" parameterType="Long" resultMap="MajorResult">
        SELECT * FROM cers_major WHERE university_id = #{universityId}
    </select>

    <!-- 根据多个专业ID查询专业信息 -->
    <select id="selectByIds" parameterType="list" resultMap="MajorResult">
        SELECT * FROM cers_major
        WHERE major_id IN
        <foreach collection="majorIds" item="majorId" open="(" separator="," close=")">
            #{majorId}
        </foreach>
    </select>

    <!-- 添加专业信息 -->
    <insert id="addMajor" parameterType="com.ruoyi.university.domain.Major">
        INSERT INTO cers_major (university_id, major_num, major_name, subject, description, min_score_2023, min_score_2024, min_score_2025)
        VALUES (#{universityId}, #{majorNum}, #{majorName}, #{subject}, #{description}, #{minScore2023}, #{minScore2024}, #{minScore2025})
    </insert>

    <!-- 更新专业信息 -->
    <update id="updateMajor" parameterType="com.ruoyi.university.domain.Major">
        UPDATE cers_major
        SET university_id = #{universityId},
            major_num = #{majorNum},
            major_name = #{majorName},
            subject = #{subject},
            description = #{description},
            min_score_2023 = #{minScore2023},
            min_score_2024 = #{minScore2024},
            min_score_2025 = #{minScore2025}
        WHERE major_id = #{majorId}
    </update>

    <!-- 删除专业信息 -->
    <delete id="deleteMajor" parameterType="Long">
        DELETE FROM cers_major WHERE major_id = #{majorId}
    </delete>

</mapper>
