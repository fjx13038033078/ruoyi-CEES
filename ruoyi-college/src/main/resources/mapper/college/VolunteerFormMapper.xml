<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.college.mapper.VolunteerFormMapper">

    <resultMap type="com.ruoyi.college.domain.VolunteerForm" id="VolunteerFormResult">
        <id property="formId" column="form_id"/>
        <result property="userId" column="user_id"/>
        <result property="formName" column="form_name"/>
        <result property="examYear" column="exam_year"/>
        <result property="batchType" column="batch_type"/>
        <result property="status" column="status"/>
        <result property="totalItems" column="total_items"/>
        <result property="warningCount" column="warning_count"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectFormListByUserId" parameterType="Long" resultMap="VolunteerFormResult">
        SELECT * FROM cers_volunteer_form WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByFormId" parameterType="Long" resultMap="VolunteerFormResult">
        SELECT * FROM cers_volunteer_form WHERE form_id = #{formId}
    </select>

    <insert id="insertForm" parameterType="com.ruoyi.college.domain.VolunteerForm" useGeneratedKeys="true" keyProperty="formId">
        INSERT INTO cers_volunteer_form (user_id, form_name, exam_year, batch_type, status, total_items, warning_count)
        VALUES (#{userId}, #{formName}, #{examYear}, #{batchType}, #{status}, #{totalItems}, #{warningCount})
    </insert>

    <update id="updateForm" parameterType="com.ruoyi.college.domain.VolunteerForm">
        UPDATE cers_volunteer_form
        <set>
            <if test="formName != null">form_name = #{formName},</if>
            <if test="examYear != null">exam_year = #{examYear},</if>
            <if test="batchType != null">batch_type = #{batchType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="totalItems != null">total_items = #{totalItems},</if>
            <if test="warningCount != null">warning_count = #{warningCount},</if>
        </set>
        WHERE form_id = #{formId}
    </update>

    <update id="updateWarningCount">
        UPDATE cers_volunteer_form SET warning_count = #{warningCount} WHERE form_id = #{formId}
    </update>

    <delete id="deleteByFormId" parameterType="Long">
        DELETE FROM cers_volunteer_form WHERE form_id = #{formId}
    </delete>

</mapper>
